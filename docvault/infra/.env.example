# ─────────────────────────────────────────────────────────────────────────────
# LocalStack (AWS emulation)
# ─────────────────────────────────────────────────────────────────────────────
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ─────────────────────────────────────────────────────────────────────────────
# S3
# ─────────────────────────────────────────────────────────────────────────────
S3_DOCUMENTS_BUCKET=documents-bucket

# ─────────────────────────────────────────────────────────────────────────────
# SNS
# ─────────────────────────────────────────────────────────────────────────────
SNS_DOCUMENT_EVENTS_ARN=arn:aws:sns:us-east-1:000000000000:document-events

# ─────────────────────────────────────────────────────────────────────────────
# SQS queue URLs
# ─────────────────────────────────────────────────────────────────────────────
SQS_INDEXING_QUEUE_URL=http://localhost:4566/000000000000/indexing-queue
SQS_DELETION_QUEUE_URL=http://localhost:4566/000000000000/deletion-queue
SQS_ACTIVITY_QUEUE_URL=http://localhost:4566/000000000000/activity-queue
SQS_EMAIL_QUEUE_URL=http://localhost:4566/000000000000/email-queue

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL (connect to existing container, docvault database)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/docvault

# ─────────────────────────────────────────────────────────────────────────────
# Qdrant
# ─────────────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ─────────────────────────────────────────────────────────────────────────────
# Infinity embedding server
# ─────────────────────────────────────────────────────────────────────────────
INFINITY_URL=http://localhost:7997
INFINITY_MODEL=BAAI/bge-small-en-v1.5

# ─────────────────────────────────────────────────────────────────────────────
# Resend (email notifications)
# Get a free API key at https://resend.com — 100 emails/day, no credit card
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTIFICATION_EMAIL_FROM=docvault@yourdomain.com
NOTIFICATION_EMAIL_TO=your@email.com

# ─────────────────────────────────────────────────────────────────────────────
# App ports
# ─────────────────────────────────────────────────────────────────────────────
API_PORT=3001
WORKER_PORT=3002
